FROM python:3.13-slim-bookworm

WORKDIR /opt/tfy-hermes-agent
ENV PYTHONUNBUFFERED=1

COPY snapshotter ./snapshotter

RUN python -m pip install --no-cache-dir --upgrade pip && \
    python -m pip install --no-cache-dir truefoundry && \
    mkdir -p /data/state /data/snapshots

CMD ["python", "snapshotter/snapshotter.py"]

# Copy to .env.local for docker compose -f docker-compose.local.yml
# Defaults work with the bundled mock LLM gateway (no real gateway needed).

TFY_API_KEY=local-test-api-key
HERMES_RUN_TOKEN_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
HERMES_MODEL=mock-model
MOCK_GATEWAY_REPLY=Local smoke OK.

# truefoundry-service + Daytona terminal (optional for local tool sandbox tests)
# HERMES_TERMINAL_BACKEND=daytona
# DAYTONA_API_KEY=
# HERMES_DAYTONA_SNAPSHOT=hermes-executor

# Optional: real gateway instead of mock-gateway
# OPENAI_BASE_URL=https://tfy-eo.truefoundry.cloud/api/llm/v1

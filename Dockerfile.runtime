FROM python:3.13-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    HERMES_HOME=/workspace/.hermes \
    HOME=/workspace \
    HERMES_STATE_OWNER=runtime

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl git gnupg ripgrep && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    apt-get purge -y --auto-remove gnupg && \
    rm -rf /var/lib/apt/lists/* && \
    python -m pip install --no-cache-dir --upgrade pip && \
    python -m pip install --no-cache-dir "hermes-agent[mcp]==0.16.0"

WORKDIR /opt/tfy-hermes-agent
COPY package.json package-lock.json ./
RUN npm ci --omit=dev --no-audit --no-fund

COPY executor ./executor
COPY runtime ./runtime

CMD ["node", "runtime/server.mjs"]

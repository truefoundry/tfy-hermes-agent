FROM python:3.13-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    HERMES_HOME=/workspace/.hermes \
    HOME=/workspace

# Debian bookworm ships Node 18; we want current LTS (24). Pull from nodesource.
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl git gnupg ripgrep && \
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    apt-get purge -y --auto-remove gnupg && \
    rm -rf /var/lib/apt/lists/* && \
    python -m pip install --no-cache-dir --upgrade pip && \
    python -m pip install --no-cache-dir "hermes-agent[mcp]==0.16.0"

WORKDIR /opt/tfy-hermes-agent
COPY executor/package.json executor/package-lock.json ./executor/
RUN cd executor && npm ci --omit=dev --no-audit --no-fund

COPY executor ./executor

CMD ["node", "executor/executor.mjs"]

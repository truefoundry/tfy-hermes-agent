FROM node:24-bookworm-slim

WORKDIR /opt/tfy-hermes-agent
ENV NODE_ENV=production

# better-sqlite3 v11.5+ ships prebuilt binaries for the active Node LTS lines
# (incl. 24) on linux + arm64/x64, but we install build deps anyway so the
# install falls back to building from source on uncommon architectures
# instead of crashing.
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates python3 make g++ && \
    rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
RUN npm ci --omit=dev --no-audit --no-fund

COPY controller ./controller

RUN mkdir -p /data/sessions

EXPOSE 8787
CMD ["node", "controller/controller.mjs"]
